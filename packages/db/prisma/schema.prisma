// Prisma スキーマ — データモデルの永続化定義（spec §5）。
// 金額は Decimal、時刻は UTC(DateTime)。PriceBar は TimescaleDB hypertable 化する
// （Prisma 管理外の生 SQL マイグレーションで変換。migrations/ に追補予定）。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── 列挙 ──
enum Market {
  JP
  US
}

enum Exchange {
  TSE
  NYSE
  NASDAQ
}

enum Currency {
  JPY
  USD
}

enum InstrumentType {
  STOCK
  ETF
}

enum Timeframe {
  m1
  m5
  m15
  h1
  d1
}

enum ManagedBy {
  HUMAN
  AGENT
}

enum OrderSide {
  BUY
  SELL
}

enum OrderType {
  MARKET
  LIMIT
  STOP
  STOP_LIMIT
}

enum TimeInForce {
  DAY
  GTC
}

enum OrderStatus {
  PENDING
  PARTIALLY_FILLED
  FILLED
  CANCELLED
  REJECTED
  EXPIRED
}

enum PositionSide {
  LONG
  SHORT
}

// 複合注文のリンク種別（Phase 5。contracts OrderLinkType）。
enum OrderLinkType {
  OCO
  IFD
}

// 注文の発効状態（Phase 5。contracts OrderActivation）。
enum OrderActivation {
  ACTIVE
  WAITING
}

// 資金区分（現物/信用。Phase 3。contracts MarginType）。
enum MarginType {
  CASH
  MARGIN
}

// 取得単価計算方式（Phase 3。contracts CostBasisMethod）。
enum CostBasisMethod {
  AVERAGE
  FIFO
  LIFO
  SPECIFIC_LOT
}

// 口座区分（特定/一般/NISA。Phase 3。contracts TaxAccountType）。
enum TaxAccountType {
  SPECIFIC
  GENERAL
  NISA
}

// 金利/貸株料の種別（Phase 3。contracts InterestAccrualType）。
enum InterestAccrualType {
  INTEREST
  BORROW_FEE
}

enum LedgerEntryType {
  DEPOSIT
  WITHDRAW
  FEE
  DIVIDEND
  TAX
  REALIZED_PNL
  TRADE
  INTEREST
  BORROW_FEE
}

enum CorporateActionType {
  DIVIDEND
  SPLIT
}

enum AgentMode {
  MANUAL_MCP
  AUTONOMOUS
}

// ── マーケットデータ ──
model Instrument {
  // 正準形式 `EXCHANGE:SYMBOL`（例 `TSE:7203` / `NASDAQ:AAPL`。contracts InstrumentId / B1）。
  // プロバイダ非依存の安定キーとして market-data / apps/api と共有するため cuid 既定は使わない。
  id        String         @id
  symbol    String
  exchange  Exchange
  market    Market
  name      String
  currency  Currency
  type      InstrumentType @default(STOCK)
  lotSize   Int            @default(1)
  tickRules Json           @default("[]")
  isActive  Boolean        @default(true)

  bars             PriceBar[]
  quotes           Quote[]
  corporateActions CorporateAction[]
  positions        Position[]
  orders           Order[]
  trades           Trade[]
  taxLots          TaxLot[]
  interestAccruals InterestAccrual[]

  @@unique([exchange, symbol])
  @@index([market])
}

model PriceBar {
  instrumentId String
  timeframe    Timeframe
  ts           DateTime
  open         Decimal
  high         Decimal
  low          Decimal
  close        Decimal
  volume       Float

  instrument Instrument @relation(fields: [instrumentId], references: [id])

  @@id([instrumentId, timeframe, ts])
  @@index([instrumentId, timeframe, ts])
}

model Quote {
  id           String   @id @default(cuid())
  instrumentId String
  last         Decimal
  bid          Decimal?
  ask          Decimal?
  ts           DateTime
  source       String

  instrument Instrument @relation(fields: [instrumentId], references: [id])

  @@index([instrumentId, ts])
}

model CorporateAction {
  id           String              @id @default(cuid())
  instrumentId String
  type         CorporateActionType
  exDate       DateTime
  value        Decimal

  instrument Instrument @relation(fields: [instrumentId], references: [id])

  @@index([instrumentId, exDate])
}

model FxRate {
  id    String   @id @default(cuid())
  base  Currency
  quote Currency
  rate  Decimal
  ts    DateTime

  @@index([base, quote, ts])
}

// ── 口座 ──
model Account {
  id             String    @id @default(cuid())
  name           String
  baseCurrency   Currency  @default(JPY)
  managedBy      ManagedBy @default(HUMAN)
  agentProfileId String?
  createdAt      DateTime  @default(now())

  agentProfile AgentProfile?         @relation(fields: [agentProfileId], references: [id])
  cashBalances CashBalance[]
  positions    Position[]
  orders       Order[]
  trades       Trade[]
  ledger       CashLedgerEntry[]
  realizedPnl  RealizedPnl[]
  taxLots      TaxLot[]
  interestAccruals InterestAccrual[]
  decisions    AgentDecision[]
  snapshots    PerformanceSnapshot[]
}

model CashBalance {
  accountId String
  currency  Currency
  amount    Decimal @default(0)

  account Account @relation(fields: [accountId], references: [id])

  @@id([accountId, currency])
}

// ── 取引 ──
model Position {
  id           String       @id @default(cuid())
  accountId    String
  instrumentId String
  side         PositionSide @default(LONG)
  quantity     Float
  avgCost      Decimal
  currency     Currency // 建玉の取引通貨（B3: 自己記述的にし換算で参照する）
  // ── 信用拡張（Phase 3。現物建玉は既定/NULL で従来挙動を維持）──
  marginType            MarginType @default(CASH)
  postedMargin          Decimal? // 拘束した保証金（MARGIN のみ）
  initialMarginRate     Decimal? // 建玉時の必要保証金率
  maintenanceMarginRate Decimal? // 維持保証金率
  annualRate            Decimal? // 適用年利（金利/貸株料）
  accruedInterest       Decimal    @default(0) // 累計の金利/貸株料（現金反映済み）
  lastAccruedAt         DateTime? // 直近の金利計上時刻
  openedAt              DateTime   @default(now())

  account    Account    @relation(fields: [accountId], references: [id])
  instrument Instrument @relation(fields: [instrumentId], references: [id])

  // 一意キーは [accountId, instrumentId, side, marginType]（Phase 5）。
  // 同一 (account, instrument, side) の CASH 現物と MARGIN 信用の同方向建玉を別行に分離する
  // （contracts POSITION_UNIQUE_KEY と一致）。marginType は @default(CASH) のため既存の現物行は
  // marginType=CASH として一意に保たれ後方互換。apps/api の upsert キーは
  // accountId_instrumentId_side → accountId_instrumentId_side_marginType へ変更が必要（申し送り）。
  @@unique([accountId, instrumentId, side, marginType])
}

model Order {
  id             String      @id @default(cuid())
  accountId      String
  instrumentId   String
  side           OrderSide
  type           OrderType
  quantity       Float
  filledQuantity Float       @default(0)
  limitPrice     Decimal?
  stopPrice      Decimal?
  timeInForce    TimeInForce @default(DAY)
  marginType     MarginType  @default(CASH) // 資金区分（Phase 3。既定 CASH=現物）
  // ── 複合注文（OCO/IFD/bracket。Phase 5。単発は NULL/ACTIVE で従来挙動）──
  linkGroupId    String? // OCO/bracket 子のグループ ID（片約定で同グループ取消）
  linkType       OrderLinkType? // OCO|IFD（単発は NULL）
  parentOrderId  String? // IFD/bracket の親注文（約定で子を発効）
  activation     OrderActivation @default(ACTIVE) // WAITING=親約定待ちで休眠
  status         OrderStatus @default(PENDING)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  account    Account    @relation(fields: [accountId], references: [id])
  instrument Instrument @relation(fields: [instrumentId], references: [id])
  trades     Trade[]

  @@index([accountId, status])
  @@index([linkGroupId])
  @@index([parentOrderId])
}

model Trade {
  id           String    @id @default(cuid())
  orderId      String
  accountId    String
  instrumentId String
  side         OrderSide
  quantity     Float
  price        Decimal
  fee          Decimal    @default(0)
  currency     Currency
  marginType   MarginType @default(CASH) // 資金区分（Phase 3。既定 CASH=現物）
  executedAt   DateTime   @default(now())

  order      Order      @relation(fields: [orderId], references: [id])
  account    Account    @relation(fields: [accountId], references: [id])
  instrument Instrument @relation(fields: [instrumentId], references: [id])

  @@index([accountId, executedAt])
}

model CashLedgerEntry {
  id        String          @id @default(cuid())
  accountId String
  type      LedgerEntryType
  currency  Currency
  amount    Decimal
  refId     String?
  ts        DateTime        @default(now())

  account Account @relation(fields: [accountId], references: [id])

  @@index([accountId, ts])
}

model RealizedPnl {
  id           String   @id @default(cuid())
  accountId    String
  instrumentId String
  quantity     Float
  costBasis    Decimal
  proceeds     Decimal
  realized     Decimal
  currency     Currency
  closedAt     DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id])

  @@index([accountId, closedAt])
}

// ── 税ロット / 信用金利（Phase 3。spec §5.1 TaxLot・信用拡張） ──
model TaxLot {
  id                String          @id @default(cuid())
  accountId         String
  instrumentId      String
  quantity          Float // 取得時数量
  remainingQuantity Float // 未決済残数量（0 でクローズ）
  costBasis         Decimal // 取得単価
  currency          Currency
  acquiredAt        DateTime        @default(now())
  method            CostBasisMethod @default(AVERAGE)
  taxAccountType    TaxAccountType  @default(SPECIFIC)
  acquiredTradeId   String? // 取得元 Trade

  account    Account    @relation(fields: [accountId], references: [id])
  instrument Instrument @relation(fields: [instrumentId], references: [id])

  @@index([accountId, instrumentId, acquiredAt])
}

model InterestAccrual {
  id           String              @id @default(cuid())
  accountId    String
  positionId   String // 対象の信用建玉
  instrumentId String
  type         InterestAccrualType
  principal    Decimal // 基準額（建玉総代金）
  annualRate   Decimal // 適用年利
  days         Int // 計上対象日数
  amount       Decimal // 発生額（費用=負）
  currency     Currency
  accruedAt    DateTime            @default(now())

  account    Account    @relation(fields: [accountId], references: [id])
  instrument Instrument @relation(fields: [instrumentId], references: [id])

  @@index([accountId, accruedAt])
  @@index([positionId, accruedAt])
}

// ── 戦略・バックテスト（Phase 0 で契約確定、実装は Phase 3） ──
model Strategy {
  id         String        @id @default(cuid())
  name       String
  definition Json
  createdAt  DateTime      @default(now())
  runs       BacktestRun[]
}

model BacktestRun {
  id         String   @id @default(cuid())
  strategyId String
  metrics    Json
  equityCurve Json
  createdAt  DateTime @default(now())

  strategy Strategy @relation(fields: [strategyId], references: [id])
}

// ── AI エージェント取引（spec §2.7） ──
model AgentProfile {
  id             String    @id @default(cuid())
  name           String
  model          String
  strategyPrompt String?
  mode           AgentMode @default(MANUAL_MCP)
  schedule       String?
  riskLimits     Json      @default("{}")
  enabled        Boolean   @default(true)
  createdAt      DateTime  @default(now())

  accounts  Account[]
  decisions AgentDecision[]
}

model AgentDecision {
  id             String   @id @default(cuid())
  agentProfileId String
  accountId      String
  ts             DateTime @default(now())
  model          String
  inputContext   Json
  rationale      String
  proposedActions Json
  resultOrderIds String[]

  agentProfile AgentProfile @relation(fields: [agentProfileId], references: [id])
  account      Account      @relation(fields: [accountId], references: [id])

  @@index([accountId, ts])
}

model PerformanceSnapshot {
  id               String   @id @default(cuid())
  accountId        String
  ts               DateTime @default(now())
  equity           Decimal
  cash             Decimal
  positionsValue   Decimal
  cumulativeReturn Float
  maxDrawdown      Float
  sharpe           Float
  winRate          Float

  account Account @relation(fields: [accountId], references: [id])

  @@index([accountId, ts])
}
