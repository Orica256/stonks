# ── データベース / Redis（ローカル Docker Compose 前提） ──
DATABASE_URL="postgresql://stonks:stonks@localhost:5432/stonks?schema=public"
REDIS_URL="redis://localhost:6379"

# ── 株価データプロバイダ（すべて無料枠。CLAUDE.md §0/§4: 有料プラン禁止） ──
# US 準リアルタイム気配（無料枠 60 req/min）
FINNHUB_API_KEY=""
# JP 権威データ（無料枠・要登録）
JQUANTS_REFRESH_TOKEN=""
# Yahoo Finance（yfinance 相当）はキー不要

# ── 為替（USD/JPY, 無料） ──
FX_API_BASE="https://api.exchangerate.host"

# ── API / アプリ ──
API_PORT="3001"
WEB_PORT="3000"
MCP_PORT="3002"

# ── 取込ワーカー（apps/ingestion-worker, BullMQ。REDIS_URL/DATABASE_URL を共有） ──
# 同時実行ジョブ数（本来のレート制御は market-data 側。二重防御で控えめに）
INGEST_CONCURRENCY="2"
# cron 登録の有効/無効（false で consumer のみ）
INGEST_SCHEDULE_ENABLED="true"
# 最新気配ポーリング cron（既定: 平日 9-23時 5分毎）
INGEST_POLL_QUOTE_CRON="*/5 9-23 * * 1-5"
# 日足取込 cron（予約）
INGEST_DAILY_BARS_CRON="0 21 * * *"
# 為替取得 cron（既定: 毎時）
INGEST_FX_CRON="0 * * * *"
# スケジュール対象銘柄（カンマ区切り EXCHANGE:SYMBOL。例 TSE:7203,NASDAQ:AAPL）
INGEST_UNIVERSE=""
# ブートストラップ・バックフィルの遡及日数
INGEST_BACKFILL_DAYS="365"

# ── AI エージェント自律ループ（任意・LLM 利用料が発生するため既定は控えめ） ──
# 自律ループのモデル。手動 MCP 売買では未使用。
AGENT_LLM_MODEL="claude-opus-4-8"
ANTHROPIC_API_KEY=""
