# ── データベース / Redis（ローカル Docker Compose 前提） ──
DATABASE_URL="postgresql://stonks:stonks@localhost:5432/stonks?schema=public"
REDIS_URL="redis://localhost:6379"

# ── 株価データプロバイダ（すべて無料枠。CLAUDE.md §0/§4: 有料プラン禁止） ──
# US 準リアルタイム気配（無料枠 60 req/min）
FINNHUB_API_KEY=""
# JP 権威データ（無料枠・要登録）
JQUANTS_REFRESH_TOKEN=""
# Yahoo Finance（yfinance 相当）はキー不要

# 信用建て可否フラグの上書き（任意・market-data, Phase 7.1。apps/api と ingestion-worker が読む）。
# カンマ区切りの `EXCHANGE:SYMBOL[:FLAG]`。FLAG は +/true/1/yes=可・-/false/0/no=不可、省略時=可。
# 信用買い（marginTradable）可否の上書き
MARGIN_TRADABLE_OVERRIDES=""
# 信用売り（shortMarginable）可否の上書き
SHORT_MARGINABLE_OVERRIDES=""

# ── 為替（USD/JPY, 無料） ──
FX_API_BASE="https://api.exchangerate.host"

# ── API / アプリ ──
API_PORT="3001"
WEB_PORT="3000"
MCP_PORT="3002"
# 口座の基軸通貨（評価額表示用。apps/api。JPY / USD）。
BASE_CURRENCY="JPY"
# オープン注文の定期評価間隔（ms。apps/api）。0 で無効（POST /orders/evaluate で手動駆動）。
ORDER_EVAL_INTERVAL_MS="0"

# ── 信用取引（MARGIN）の既定ポリシー（apps/api, Phase 6。シミュレーション既定値） ──
# 率はすべて非負小数文字列（例 0.30 = 30%）。未設定なら下記の既定値を使う。
# 必要保証金率（建玉時。既定 0.30）
MARGIN_INITIAL_RATE="0.30"
# 維持保証金率（追証ライン。既定 0.20）
MARGIN_MAINTENANCE_RATE="0.20"
# 買い建て金利（年利。既定 0.028）
MARGIN_ANNUAL_INTEREST_RATE="0.028"
# 売り建て貸株料（年利・任意。既定 0.011）
MARGIN_ANNUAL_BORROW_RATE="0.011"
# 信用不可銘柄（カンマ区切りの EXCHANGE:SYMBOL）。含む銘柄は MARGIN 発注を拒否。既定は空。
MARGIN_DISALLOWED_INSTRUMENTS=""

# ── 成績比較ベンチマーク銘柄（apps/api, analytics の compare で使用） ──
# 各ベンチに対応する instrumentId（EXCHANGE:SYMBOL）。未設定のベンチは比較不可。
# BUY_AND_HOLD の買い持ち銘柄
AGENT_BENCHMARK_BUY_AND_HOLD=""
# TOPIX 指数に対応する銘柄
AGENT_BENCHMARK_TOPIX=""
# S&P500 指数に対応する銘柄
AGENT_BENCHMARK_SP500=""

# ── 取込ワーカー（apps/ingestion-worker, BullMQ。REDIS_URL/DATABASE_URL を共有） ──
# 同時実行ジョブ数（本来のレート制御は market-data 側。二重防御で控えめに）
INGEST_CONCURRENCY="2"
# cron 登録の有効/無効（false で consumer のみ）
INGEST_SCHEDULE_ENABLED="true"
# 最新気配ポーリング cron（既定: 平日 9-23時 5分毎）
INGEST_POLL_QUOTE_CRON="*/5 9-23 * * 1-5"
# 日足取込 cron（予約）
INGEST_DAILY_BARS_CRON="0 21 * * *"
# 為替取得 cron（既定: 毎時）
INGEST_FX_CRON="0 * * * *"
# スケジュール対象銘柄（カンマ区切り EXCHANGE:SYMBOL。例 TSE:7203,NASDAQ:AAPL）
INGEST_UNIVERSE=""
# ブートストラップ・バックフィルの遡及日数
INGEST_BACKFILL_DAYS="365"
# 分足取込 cron（既定: 5 分毎）
INGEST_INTRADAY_BARS_CRON="*/5 * * * *"
# 定期取込する分足足種（カンマ区切り 1m,5m,15m,1h。未知値・1d は無視。空で分足取込なし）
INGEST_INTRADAY_TIMEFRAMES="1m"
# 分足取込で毎回さかのぼる分数（取りこぼし防止。cron 間隔より長く）
INGEST_INTRADAY_LOOKBACK_MIN="120"

# ── MCP ツールサーバー（apps/mcp-server, stdio。apps/api の薄いラッパ） ──
# 叩く api のベース URL（未指定なら http://localhost:${API_PORT}）。
MCP_API_BASE_URL="http://localhost:3001"
# place_order で agentProfileId 未指定時に使う既定プロファイル（監査証跡 AgentDecision 用）。
MCP_DEFAULT_AGENT_PROFILE_ID=""
# api 呼び出しタイムアウト（ms）。
MCP_REQUEST_TIMEOUT_MS="15000"

# ── AI エージェント自律ループ（apps/agent-runner, BullMQ, P1） ──
# ★ LLM 利用料が発生しうるため既定は控えめ（disabled・1日1回・無LLMのHOLD）。
# 自律ループのモデル名（手動 MCP 売買では未使用。provider=llm で Anthropic に渡す）。
AGENT_LLM_MODEL="claude-opus-4-8"
# 実 LLM（Anthropic Claude）の API キー（provider=llm 用。秘密情報・コミット禁止）。
# 設定があり provider=llm のときのみ実 LLM を呼ぶ＝LLM 利用料が別途発生（アプリのインフラ
# 無料制約とは別枠。spec §2.7）。未設定なら provider=llm でも HOLD にフォールバック（無課金）。
ANTHROPIC_API_KEY=""
# 自律ループを有効化するか。既定 false（明示的にオプトインさせる。暴走/課金防止）。
AGENT_RUNNER_ENABLED="false"
# 叩く api のベース URL（未指定なら http://localhost:${API_PORT}）。
AGENT_RUNNER_API_BASE_URL="http://localhost:3001"
# api 呼び出しタイムアウト（ms）。
AGENT_RUNNER_REQUEST_TIMEOUT_MS="15000"
# 回す対象の AGENT 口座 ID と発注主体のエージェントプロファイル ID（監査証跡に必須）。
AGENT_RUNNER_ACCOUNT_ID=""
AGENT_RUNNER_PROFILE_ID=""
# 判断プロバイダ。hold=無LLM安全既定 / llm=実LLM呼び出し（課金、要 ANTHROPIC_API_KEY）。
AGENT_RUNNER_PROVIDER="hold"
# 自律ループの cron（既定: 毎日 0:00 UTC 1回。頻度・課金を控えめに）。
AGENT_RUNNER_CRON="0 0 * * *"
# 1 ループあたりの最大発注（ORDER/CANCEL）数。超過分は捨てる（暴走防止の二重防御）。
AGENT_RUNNER_MAX_ACTIONS="3"
# BullMQ の繰り返し登録を行うか（false なら consumer のみ。手動 enqueue 用）。
AGENT_RUNNER_SCHEDULE_ENABLED="true"

# ── Web フロント（apps/web, Next.js。NEXT_PUBLIC_* はクライアントに露出。秘密禁止） ──
# 叩く api のベース URL（未指定なら http://localhost:3001）。
NEXT_PUBLIC_API_BASE_URL="http://localhost:3001"
# 既定の口座 ID（単一ローカルユーザ前提。未指定なら "default"）。
NEXT_PUBLIC_DEFAULT_ACCOUNT_ID="default"
