# ── データベース / Redis（ローカル Docker Compose 前提） ──
DATABASE_URL="postgresql://stonks:stonks@localhost:5432/stonks?schema=public"
REDIS_URL="redis://localhost:6379"

# ── 株価データプロバイダ（すべて無料枠。CLAUDE.md §0/§4: 有料プラン禁止） ──
# US 準リアルタイム気配（無料枠 60 req/min）
FINNHUB_API_KEY=""
# JP 権威データ（無料枠・要登録）
JQUANTS_REFRESH_TOKEN=""
# Yahoo Finance（yfinance 相当）はキー不要

# ── 為替（USD/JPY, 無料） ──
FX_API_BASE="https://api.exchangerate.host"

# ── API / アプリ ──
API_PORT="3001"
WEB_PORT="3000"
MCP_PORT="3002"

# ── AI エージェント自律ループ（任意・LLM 利用料が発生するため既定は控えめ） ──
# 自律ループのモデル。手動 MCP 売買では未使用。
AGENT_LLM_MODEL="claude-opus-4-8"
ANTHROPIC_API_KEY=""
