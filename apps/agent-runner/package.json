{
  "name": "@stonks/agent-runner",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/main.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "dev": "node --import tsx/esm --watch src/main.ts",
