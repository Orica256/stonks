    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@stonks/config": "workspace:*",
    "@types/node": "^20.16.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
