# apps/api — 環境変数サンプル（秘密情報は .env に。コミット禁止）

# HTTP ポート
PORT=3001

# 口座の基軸通貨（評価額表示用）。JPY / USD
BASE_CURRENCY=JPY

# ── 永続化 ──
# Prisma 接続先。設定されていればオープン注文の定期評価とリポジトリが DB を使う。
DATABASE_URL=postgresql://stonks:stonks@localhost:5432/stonks?schema=public

# ── market-data アダプタ（未設定でも Yahoo で動作する） ──
# US 準リアルタイム気配（任意）
FINNHUB_API_KEY=
# JP 権威データ（任意・要登録）
JQUANTS_REFRESH_TOKEN=
# 為替 API ベース URL（任意。既定 exchangerate.host）
FX_API_BASE=

# ── 信用建て可否フラグの上書き（任意・market-data, Phase 7.1） ──
# カンマ区切りの `EXCHANGE:SYMBOL[:FLAG]`。FLAG は +/true/1/yes=可・-/false/0/no=不可、
# 省略時は可。ルール既定（margin-eligibility）を銘柄単位で上書きする。既定は空。
# 信用買い（marginTradable）可否の上書き
MARGIN_TRADABLE_OVERRIDES=
# 信用売り（shortMarginable）可否の上書き
SHORT_MARGINABLE_OVERRIDES=

# ── 成績比較ベンチマーク銘柄（任意・analytics の compare で使用） ──
# 各ベンチに対応する instrumentId（EXCHANGE:SYMBOL）。未設定のベンチは比較不可。
# BUY_AND_HOLD の買い持ち銘柄
AGENT_BENCHMARK_BUY_AND_HOLD=
# TOPIX 指数に対応する銘柄
AGENT_BENCHMARK_TOPIX=
# S&P500 指数に対応する銘柄
AGENT_BENCHMARK_SP500=

# ── オープン注文の定期評価 ──
# 評価インターバル（ms）。0 で無効（POST /orders/evaluate で手動駆動）。
ORDER_EVAL_INTERVAL_MS=0

# ── 信用取引（MARGIN）の既定ポリシー（シミュレーション既定値。投資情報の断定ではない） ──
# 率はすべて非負小数文字列（例 0.30 = 30%）。未設定なら下記の既定値を使う。
# 必要保証金率（建玉時）
MARGIN_INITIAL_RATE=0.30
# 維持保証金率（追証ライン）
MARGIN_MAINTENANCE_RATE=0.20
# 買い建て金利（年利）
MARGIN_ANNUAL_INTEREST_RATE=0.028
# 売り建て貸株料（年利・任意）
MARGIN_ANNUAL_BORROW_RATE=0.011
# 信用不可銘柄（カンマ区切りの EXCHANGE:SYMBOL）。ここに含む銘柄は MARGIN 発注を拒否。既定は空。
MARGIN_DISALLOWED_INSTRUMENTS=
