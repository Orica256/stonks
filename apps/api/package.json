    "@stonks/analytics": "workspace:*",
    "@stonks/contracts": "workspace:*",
    "@stonks/core-domain": "workspace:*",
    "@stonks/db": "workspace:*",
    "@stonks/market-data": "workspace:*",
    "@stonks/portfolio": "workspace:*",
    "@stonks/trading-engine": "workspace:*",
    "decimal.js": "^10.4.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.4",
    "@stonks/config": "workspace:*",
    "@swc/core": "^1.7.26",
    "unplugin-swc": "^1.5.1",
    "@types/express": "^4.17.21",
    "@types/node": "^20.16.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
